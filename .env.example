# Copy this file to .env and fill in your values.
# .env is in .gitignore — never commit real keys.

# ── LLM Provider ──────────────────────────────────────────────────────────────
# Choose one: gemini | anthropic | ollama
MODEL_PROVIDER=ollama

# Gemini (default provider, free tier 1 500 req/day)
GOOGLE_API_KEY=your-google-api-key-here
GEMINI_MODEL=gemini-2.5-flash

# Anthropic Claude Haiku (fallback when Gemini quota is exhausted)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Ollama (fully local, no API key required — ollama must be running)
OLLAMA_MODEL=gemma4:e2b-it-qat
OLLAMA_URL=http://localhost:11434

# ── Whisper ───────────────────────────────────────────────────────────────────
# Options: tiny | base | base.en | small | medium (larger = slower + more accurate)
WHISPER_MODEL=base

# ── Flask ─────────────────────────────────────────────────────────────────────
# Set to "development" to skip API key auth during local rehearsal
FLASK_ENV=development
API_KEY=dev-key-change-in-production

# ── Audit log ─────────────────────────────────────────────────────────────────
AUDIT_LOG=audit.jsonl
